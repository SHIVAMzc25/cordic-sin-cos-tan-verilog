# =============================================================================
# .gitignore for Xilinx Vivado Projects
# =============================================================================

# Vivado project files (regeneratable)
*.jou
*.log
*.str
*.mif

# Project directories generated by Vivado
.Xil/
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.srcs/utils_1/
*.gen/
*.xpr.bak

# Vivado HLS
*.axi/
solution*/
vivado_hls.app

# Synplify
synwork/
syntmp/
*.srr

# ModelSim / QuestaSim
work/
transcript
vsim.wlf
*.vcd
*.wlf

# ISE legacy
*.ise
*.xise
*.stx
*.gise
*.bgn
*.drc
*.ncd
*.ngd
*.ngr
*.ngm
*.pcf
*.par
*.pad
*.twr
*.twx
*.unroutes
*.ut
*.xwbt
ise/

# Bitstream / device files (large binary)
*.bit
*.bin
*.ltx

# Waveform databases
*.wcfg
*.vcd
*.fsdb

# OS-specific
Thumbs.db
.DS_Store
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*~
